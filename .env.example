# Copy to .env and fill in values.

# Prisma / SQLite database file. Path is relative to the repo root.
DATABASE_URL="file:./prisma/dev.db"

# Claude API key for the /api/chat endpoint (Stage 2+). Server-side only.
ANTHROPIC_API_KEY=""

# Optional: override photo upload directory. Defaults to <repo>/uploads.
# UPLOAD_DIR=""
